# =============================================================================
# Environment variables for apps/web
# =============================================================================
#
# Copy this file to apps/web/.env.local and fill in only the variables you need
# for the surfaces you intend to run.
#
# The PUBLIC portfolio surface (home, /about, /faq, /now, /uses, /reading,
# /projects, /blog) renders without ANY of these variables. You only need them
# if you're going to run the auth-gated chat playground locally.
#
# In production, all of these are managed in the Vercel project settings.

# -----------------------------------------------------------------------------
# AUTH (next-auth v5)
# -----------------------------------------------------------------------------
# Required by /chat, /login, /register, and the auth API route.
# Generate with: `openssl rand -base64 32`
AUTH_SECRET=

# -----------------------------------------------------------------------------
# AI providers — required by /api/chat
# -----------------------------------------------------------------------------
# At least one of XAI_API_KEY / GOOGLE_AI_API_KEY / OPENROUTER_API_KEY is needed
# for the chat to actually answer; choose based on which model you target.

# xAI Grok models
# https://console.x.ai/
XAI_API_KEY=

# Google AI Studio (Gemini)
# https://aistudio.google.com/
GOOGLE_AI_API_KEY=

# OpenRouter — unified gateway across model providers
# https://openrouter.ai
OPENROUTER_API_KEY=
OPENROUTER_SITE_URL=https://www.aryateja.com
OPENROUTER_SITE_NAME=aryateja.com
OPENROUTER_CHAT_MODEL=openai/gpt-4o

# -----------------------------------------------------------------------------
# Vercel-managed services — required by /chat persistence and uploads
# -----------------------------------------------------------------------------
# In production these are auto-injected when you connect Vercel Blob and Postgres.

# Vercel Blob (uploaded artifacts in /chat)
# https://vercel.com/docs/storage/vercel-blob
BLOB_READ_WRITE_TOKEN=

# Vercel Postgres (chat history persistence). Drizzle migrations run from this.
# https://vercel.com/docs/storage/vercel-postgres/quickstart
POSTGRES_URL=

# -----------------------------------------------------------------------------
# Analytics
# -----------------------------------------------------------------------------
# Google Analytics property id. The portfolio layout falls back to a default
# in development; production should always set this.
NEXT_PUBLIC_GA_ID=

# -----------------------------------------------------------------------------
# IndexNow (optional — post-publish URL ping)
# -----------------------------------------------------------------------------
# Used by: `bun run indexnow ...` — see docs/SEO-AEO.md or apps/web/scripts/indexnow.mjs
# Provide the same key file at https://www.aryateja.com/<INDEXNOW_KEY>.txt (plain text body = key).
INDEXNOW_KEY=
INDEXNOW_HOST=https://www.aryateja.com
